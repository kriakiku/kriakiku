#!/bin/bash
set -e

ENV_FILE="/opt/work/env.sh"
ERROR_LOG="/opt/work/error.log"
TOKEN_NAME="DevPod"

log_error() {
  echo "[ERROR] $(date '+%Y-%m-%d %H:%M:%S') $1" >> "$ERROR_LOG"
}

echo "Rotating GitLab token for user @me with name '$TOKEN_NAME'..."

source "$ENV_FILE"
export GITLAB_TOKEN="$GITLAB_TOKEN"

# Try to rotate token safely
TMP_ERR=$(mktemp)
if ! TOKEN=$(glab token rotate --user @me "$TOKEN_NAME" --duration 90d -F text 2>"$TMP_ERR"); then
  ERROR_MSG=$(<"$TMP_ERR")
  rm -f "$TMP_ERR"
  log_error "Failed to rotate GitLab token: $ERROR_MSG"
  echo "Token rotation failed, see $ERROR_LOG"
  exit 0
fi
rm -f "$TMP_ERR"

# Validate token content before updating env file
if [[ -z "$TOKEN" || "$TOKEN" =~ [[:space:]] || "$TOKEN" == *"ERROR"* || "$TOKEN" == *"error"* || "$TOKEN" == *"Could not"* || "$TOKEN" == *"Get "* ]]; then
  log_error "Invalid token received from glab token rotate: $TOKEN"
  echo "Token rotation failed, see $ERROR_LOG"
  exit 0
fi

echo "Updating GITLAB_TOKEN in $ENV_FILE..."

# Ensure file exists
if [ ! -f "$ENV_FILE" ]; then
  log_error "$ENV_FILE does not exist"
  echo "Env file missing, see $ERROR_LOG"
  exit 0
fi

# Try to update env file safely
export TOKEN="$TOKEN"
awk '
BEGIN {updated=0}
{
  if ($0 ~ /^export GITLAB_TOKEN=/) {
    print "export GITLAB_TOKEN=\"" ENVIRON["TOKEN"] "\""
    updated=1
  } else {
    print
  }
}
END {
  if (!updated) print "export GITLAB_TOKEN=\"" ENVIRON["TOKEN"] "\""
}
' "$ENV_FILE" > "$ENV_FILE.tmp" && mv "$ENV_FILE.tmp" "$ENV_FILE"

echo "GITLAB_TOKEN has been updated in $ENV_FILE"

# Update environment variables (also safe)
if ! devcontainer-env; then
  log_error "devcontainer-env failed after token update"
  echo "devcontainer-env failed, see $ERROR_LOG"
fi
