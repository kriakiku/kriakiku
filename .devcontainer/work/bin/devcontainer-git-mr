#!/usr/bin/env bash
set -euo pipefail

git fetch origin development

BASE="origin/development"

TITLE="$(git log -n 50 --pretty=%s --no-merges \
  | tr -d '\r' \
  | grep -m 1 -E '^[A-Z]{2,3}-[0-9]+')"

DESCRIPTION="$(git log $BASE..HEAD --pretty=%s --no-merges \
  | tr -d '\r' \
  | grep -E '^[A-Z]{2,3}-[0-9]+' \
  | awk '!seen[$0]++')"

OUTPUT="$(git push origin HEAD \
  -o merge_request.create \
  -o merge_request.target=development \
  -o merge_request.title="$TITLE" \
  -o merge_request.description="$(printf "%s\n" "$DESCRIPTION")" \
  -o merge_request.auto_merge \
  -o merge_request.remove_source_branch \
  -o merge_request.squash 2>&1)"

LINK="$(echo "$OUTPUT" | grep -Eo 'https?://[^ )]+' | head -n 1)"

if [[ -n "${LINK:-}" ]]; then
  echo "- $LINK" >> /opt/work/merge-requests.md
  code /opt/work/merge-requests.md
fi
