#!/bin/bash
set -e

echo "Ensuring frontends.code-workspace exists..."
if [ ! -f /opt/work/frontends.code-workspace ]; then
  jq -n '{folders: [], settings: {}}' > /opt/work/frontends.code-workspace
fi

tmp=$(mktemp)
tsdk="$(npm root -g)/typescript/lib"

for file in /opt/work/*.code-workspace; do
  [ -e "$file" ] || continue
  echo "Updating $file with TypeScript SDK path and random pet theme..."
  tmp="$(mktemp)"
  
  themes=("forest" "castle" "beach" "autumn")
  theme=${themes[$RANDOM % ${#themes[@]}]}

  jq --arg tsdk "$tsdk" --arg theme "$theme" '
    .settings |= (
      . // {}
      | .["js/ts.tsdk.path"] = $tsdk
      | .["vscode-pets.theme"] = $theme
    )
  ' "$file" > "$tmp" && mv "$tmp" "$file"
done

echo "Dynamic configuration applied successfully."
