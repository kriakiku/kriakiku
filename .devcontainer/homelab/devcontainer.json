{
	"name": "Homelab",
    "dockerComposeFile": "compose.yaml",
    "service": "homelab",
    "remoteUser": "root",
    "updateRemoteUserUID": false,
	"features": {
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers/features/git-lfs:1": {},
        "ghcr.io/devcontainers/features/common-utils:2": { "configureZshAsDefaultShell": true },
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
            "moby": false
        },
        "ghcr.io/devcontainers/features/go:1": { "version": "latest" },
        "ghcr.io/devcontainers/features/python:1": {},
        "ghcr.io/devcontainers/features/node:2": {},
        "ghcr.io/devcontainers-extra/features/bun:1": {},
        "ghcr.io/devcontainers-extra/features/gitomatic:1": {},
        "ghcr.io/devcontainers-extra/features/typescript:2": {},
        "ghcr.io/devcontainers/features/nix:1": {}
    },

    "workspaceFolder": "/opt/homelab",

    "updateContentCommand": "devcontainer-post-update",
    "postStartCommand": "devcontainer-post-start",
    "postAttachCommand": "devcontainer-post-attach",

	"customizations": {
        "vscode": {
			"settings": {
                "terminal.integrated.defaultProfile.linux": "zsh",
                "editor.fontFamily": "AtkynsonMono NFP",
                "jestrunner.enableTestExplorer": true,

                "editor.defaultFormatter": "esbenp.prettier-vscode",
                "files.autoSave": "afterDelay",
                "eslint.format.enable": false,
                "editor.formatOnSave": true,
                "editor.codeActionsOnSave": {
                    "source.fixAll.prettier": "explicit",
                    "source.fixAll.eslint": "explicit"
                },
                "editor.unicodeHighlight.allowedCharacters": {
                    "’": true
                },
                "editor.accessibilitySupport": "on",
                "[go]": { "editor.defaultFormatter": "golang.go" },
                "[javascript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
                "[javascriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
                "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
                "[typescriptreact]": {
                    "editor.defaultFormatter": "esbenp.prettier-vscode"
                    // "editor.defaultFormatter": "vscode.typescript-language-features",
                },
                "[dockercompose]": {
                    "editor.insertSpaces": true,
                    "editor.tabSize": 2,
                    "editor.autoIndent": "advanced",
                    "editor.defaultFormatter": "redhat.vscode-yaml",
                },

                "workbench.colorTheme": "GitHub Light Colorblind (Beta)",
                "workbench.iconTheme": "material-icon-theme",
                "explorer.compactFolders": false,

                "git.ignoreRebaseWarning": true,
                "chat.disableAIFeatures": true,
                "gitlab.duoChat.enabled": false,

                "vscode-pets.theme": "beach",
                "vscode-pets.petColor": "pink",
                "vscode-pets.petSize": "medium",
                "vscode-pets.throwBallWithMouse": true
            },
			"extensions": [
                "firsttris.vscode-jest-runner",
                "aaron-bond.better-comments",
                "mikestead.dotenv",
                "github.github-vscode-theme",
                "jdinhlife.gruvbox",
                "mrmlnc.vscode-json5",
                "pkief.material-icon-theme",
                "william-voyek.vscode-nginx",
                "simonsiefke.svg-preview",
                "mariusschulz.yarn-lock-syntax",
                "dunstontc.vscode-go-syntax",
                "atlassian.atlascode",
                "streetsidesoftware.code-spell-checker",
                "editorconfig.editorconfig",
                "dbaeumer.vscode-eslint",
                "google.geminicodeassist",
                "eamodio.gitlens",
                "golang.go",
                "ms-vscode.vscode-typescript-next",
                "esbenp.prettier-vscode",
                "stylelint.vscode-stylelint",
                "tonybaloney.vscode-pets",
                "redhat.vscode-yaml"
            ]
        }
    }
}
